#!/usr/bin/env python3
import os
import sys
import subprocess

# Shared function for both environments
def check_status():
    try:
        res = subprocess.run(['warp-cli', 'status'], capture_output=True, text=True)
        return "Connected" in res.stdout
    except:
        return False

# Detect the current desktop environment
desktop = os.environ.get('XDG_CURRENT_DESKTOP', '').lower()

if 'kde' in desktop:
    # --- KDE PLASMA (QT6) ENGINE ---
    from PyQt6.QtWidgets import QApplication, QSystemTrayIcon
    from PyQt6.QtGui import QIcon
    from PyQt6.QtCore import QTimer

    def toggle(reason):
        if reason == QSystemTrayIcon.ActivationReason.Trigger:
            if check_status():
                subprocess.run(['warp-cli', 'disconnect'])
                subprocess.run(['notify-send', 'Cloudflare WARP', 'Disconnected', '--icon=network-offline'])
            else:
                subprocess.run(['warp-cli', 'connect'])
                subprocess.run(['notify-send', 'Cloudflare WARP', 'Connected (Tunnel Only)', '--icon=network-vpn'])
            update_ui()

    def update_ui():
        if check_status():
            tray.setIcon(icon_green)
            tray.setToolTip("CloudflareWARP VPN on")
        else:
            tray.setIcon(icon_red)
            tray.setToolTip("CloudflareWARP VPN off")

    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(False)
    home = os.path.expanduser('~')
    icon_green = QIcon(f"{home}/.local/share/icons/warp-green.svg")
    icon_red = QIcon(f"{home}/.local/share/icons/warp-red.svg")
    tray = QSystemTrayIcon()
    update_ui()
    tray.setVisible(True)
    tray.activated.connect(toggle)
    timer = QTimer()
    timer.timeout.connect(update_ui)
    timer.start(2000)
    sys.exit(app.exec())

elif 'cinnamon' in desktop or 'x-cinnamon' in desktop:
    # --- CINNAMON (XAPP/GTK) ENGINE ---
    import gi
    gi.require_version('Gtk', '3.0')
    gi.require_version('XApp', '1.0')
    from gi.repository import Gtk, XApp, GLib

    def on_click(icon, x, y, button, time, panel_position):
        if button != 1:
            return
        if check_status():
            os.system("warp-cli disconnect &")
            os.system("notify-send 'Cloudflare WARP' 'Disconnected' --icon=network-offline &")
        else:
            os.system("warp-cli connect &")
            os.system("notify-send 'Cloudflare WARP' 'Connected (Tunnel Only)' --icon=network-vpn &")
        GLib.timeout_add(100, update_ui)

    def update_ui():
        if check_status():
            icon.set_icon_name(icon_green)
            icon.set_tooltip_text("CloudflareWARP VPN on")
        else:
            icon.set_icon_name(icon_red)
            icon.set_tooltip_text("CloudflareWARP VPN off")
        return True

    home = os.path.expanduser('~')
    icon_green = f"{home}/.local/share/icons/warp-green.svg"
    icon_red = f"{home}/.local/share/icons/warp-red.svg"
    icon = XApp.StatusIcon()
    icon.connect("button-release-event", on_click)
    update_ui()
    GLib.timeout_add(2000, update_ui)
    Gtk.main()

else:
    print(f"Unsupported desktop environment: {desktop}")
    sys.exit(1)
